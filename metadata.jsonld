  "hasPart": [
    {
      "@type": "LearningResource",
      "name": "Technologien verstehen: Semantic Web & Linked Data",
      "description": "Dieses Kapitel vermittelt Kenntnisse in den grundlegenden Konzepten des Semantic Web und Linked Data.",
      "url": "https://quadriga-dk.github.io/Tabelle-Fallstudie-2/semantic_web/Semantic_Web_Linked_Data.html",
      "timeRequired": "PT30M",
      "teaches": "Technologien verstehen",
      "educationalAlignment": [
        {
          "@type": "AlignmentObject",
          "targetName": "Der Begriff Semantic Web kann definiert werden.",
          "educationalFramework": "QUADRIGA Competency Framework",
          "targetDescription": "Competency: Orientierungswissen | Bloom's: 1 Erinnern | Data Flow: übergreifend",
          "lrmi:assesses": "Multiple-Choice-Quiz, Reflexionsfragen"
        }
      ]
    },
    {
      "@type": "LearningResource",
      "name": "Werkzeuge kennenlernen: DCAT-AP Metadatenstandard",
      "description": "Dieses Kapitel widmet sich Metadaten, Metadatenportalen und dem Metadatenstandard DCAT sowie dessen Anwendungsprofil DCAT-AP und dem auf Deutschland angepassten Profil DCAT-AP.de.",
      "url": "https://quadriga-dk.github.io/Tabelle-Fallstudie-2/dcat_ap/DCAT_AP_Metadatenstandard.html",
      "timeRequired": "PT30M",
      "teaches": "Metadatenstandards",
      "educationalAlignment": [
        {
          "@type": "AlignmentObject",
          "targetName": "Der DCAT-Standard kann definiert werden.",
          "educationalFramework": "QUADRIGA Competency Framework",
          "targetDescription": "Competency: 3.2 Erschließung | Bloom's: 2 Verstehen | Data Flow: 3 Management",
          "lrmi:assesses": "Multiple-Choice-Quiz, Reflexionsfragen"
        },
        {
          "@type": "AlignmentObject",
          "targetName": "Vier Hauptmerkmale des Dublin Core-Metadatenstandards können genannt werden.",
          "educationalFramework": "QUADRIGA Competency Framework",
          "targetDescription": "Competency: 3.2 Erschließung | Bloom's: 1 Erinnern | Data Flow: 3 Management",
          "lrmi:assesses": "Multiple-Choice-Quiz, Reflexionsfragen"
        },
        {
          "@type": "AlignmentObject",
          "targetName": "Die Ableitung von DCAT-AP.de aus DCAT-AP und dessen Anwendung in Deutschland kann erläutert werden.",
          "educationalFramework": "QUADRIGA Competency Framework",
          "targetDescription": "Competency: 3.2 Erschließung | Bloom's: 2 Verstehen | Data Flow: 3 Management",
          "lrmi:assesses": "Multiple-Choice-Quiz, Reflexionsfragen"
        }
      ]
    },
    {
      "@type": "LearningResource",
      "name": "Datenqualität messen: Metadata Quality Assessment",
      "description": "Dieses Kapitel widmet sich der Qualität von Metadaten und deren Bedeutung für die Nachnutzung offener Daten.",
      "url": "https://quadriga-dk.github.io/Tabelle-Fallstudie-2/metadatenqualit%C3%A4t/Metadatenqualit%C3%A4t.html",
      "timeRequired": "PT20M",
      "teaches": "Metadatenqualität",
      "educationalAlignment": [
        {
          "@type": "AlignmentObject",
          "targetName": "Die Funktionen des Metadata Quality Assessment (MQA) können beschrieben werden.",
          "educationalFramework": "QUADRIGA Competency Framework",
          "targetDescription": "Competency: 1.2 Qualitätssicherung | Bloom's: 2 Verstehen | Data Flow: 1 Planung",
          "lrmi:assesses": "Multiple-Choice-Quiz, Reflexionsfragen"
        }
      ]
    },
    {
      "@type": "LearningResource",
      "name": "Praxis anwenden: SPARQL-Abfragen",
      "description": "In diesem Kapitel wird die Abfragesprache SPARQL vorgestellt",
      "url": "https://quadriga-dk.github.io/Tabelle-Fallstudie-2/sparql/SPARQL.html",
      "timeRequired": "PT40M",
      "teaches": "Abfragesprache SPARQL",
      "educationalAlignment": [
        {
          "@type": "AlignmentObject",
          "targetName": "Die grundlegenden Komponenten der SPARQL-Syntax können aufgezählt und ihre Rollen erläutert werden.",
          "educationalFramework": "QUADRIGA Competency Framework",
          "targetDescription": "Competency: 1.1 Identifikation | Bloom's: 2 Verstehen | Data Flow: 1 Planung",
          "lrmi:assesses": "Multiple-Choice-Quiz, Reflexionsfragen"
        },
        {
          "@type": "AlignmentObject",
          "targetName": "Einfache SPARQL-Abfragen können erstellt und durchgeführt werden, um spezifische Informationen aus einem Datenkatalog abzurufen.",
          "educationalFramework": "QUADRIGA Competency Framework",
          "targetDescription": "Competency: 1.1 Identifikation | Bloom's: 3 Anwenden | Data Flow: 1 Planung",
          "lrmi:assesses": "Multiple-Choice-Quiz, Reflexionsfragen"
        }
      ]
    }
  ],
